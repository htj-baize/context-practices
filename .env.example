# Optional GitHub token for cloning private context-family repositories over HTTPS.
# If omitted, bootstrap falls back to SSH repository URLs.
CONTEXT_GITHUB_TOKEN=

# Optional Neta token for Neta-powered cases.
NETA_TOKEN=

# Optional Neta API base URLs. Omit to use the upstream defaults from neta-skills.
NETA_API_BASE_URL=
NETA_AUTH_API_BASE_URL=

# Optional vendored neta-skills source for the local GitHub bootstrap path.
# NETA_REPO_URL should be a git clone URL.
# NETA_REPO_REF should be a branch, tag, or commit to checkout after clone/fetch.
NETA_REPO_URL=
NETA_REPO_REF=

# Optional recommender LLM settings for the Neta next-collection case.
NETA_RECOMMENDER_LLM_ENDPOINT=
NETA_RECOMMENDER_LLM_API_KEY=
NETA_RECOMMENDER_LLM_MODEL=
NETA_RECOMMENDER_LLM_API_PATH=
