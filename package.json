{
  "name": "context-practices",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @context-practices/practices-web dev",
    "build": "pnpm --filter @context-practices/practices-web build",
    "start": "pnpm --filter @context-practices/practices-web start",
    "lint": "pnpm --filter @context-practices/practices-web lint",
    "typecheck": "pnpm --filter @context-practices/practices-web typecheck",
    "check": "pnpm lint && pnpm typecheck"
  }
}
