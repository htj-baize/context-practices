# Copy this file to .env.local and fill in the values you need.

# Preferred auth path for the local vendored neta-cli.
NETA_TOKEN=

# Optional: override API base if your environment does not use the default.
# NETA_API_BASE_URL=

# Optional: pin a specific vendored repo ref during setup-local-neta-from-github.
# NETA_REPO_REF=
